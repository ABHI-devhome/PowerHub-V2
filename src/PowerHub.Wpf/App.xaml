<Application x:Class="PowerHub.UI.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml">
  <Application.Resources>
    <ResourceDictionary>
      <ResourceDictionary.MergedDictionaries>
        <!-- WPF-UI Core -->
        <ui:ThemesDictionary Theme="Dark" />
        <ui:ControlsDictionary />
        
        <!-- App Design System -->
        <ResourceDictionary Source="pack://application:,,,/Resources/Colors.xaml" />
        <ResourceDictionary Source="pack://application:,,,/Resources/Typography.xaml" />
        <ResourceDictionary Source="pack://application:,,,/Resources/Controls.xaml" />
      </ResourceDictionary.MergedDictionaries>
    </ResourceDictionary>
  </Application.Resources>
</Application>
