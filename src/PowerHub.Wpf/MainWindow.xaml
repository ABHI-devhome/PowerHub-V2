<ui:FluentWindow x:Class="PowerHub.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        Title="PowerHub Digital Utility"
        Height="900"
        Width="1440"
        MinWidth="1100"
        MinHeight="700"
        WindowStartupLocation="CenterScreen"
        WindowBackdropType="Mica"
        ExtendsContentIntoTitleBar="True">
  <Grid>
    <Grid.RowDefinitions>
        <RowDefinition Height="Auto" />
        <RowDefinition Height="*" />
    </Grid.RowDefinitions>
    
    <ui:TitleBar Title="PowerHub Digital Utility" Grid.Row="0" />

    <Grid Grid.Row="1">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        
        <ui:NavigationView Grid.Column="0" x:Name="RootNavigation" Header="PowerHub" PaneDisplayMode="Left">
          <ui:NavigationView.MenuItems>
            <ui:NavigationViewItem Content="Dashboard" Icon="{ui:SymbolIcon Dashboard24}" />
            <ui:NavigationViewItem Content="Power Plans" Icon="{ui:SymbolIcon BatteryCharging24}" />
            <ui:NavigationViewItem Content="Display" Icon="{ui:SymbolIcon Desktop24}"  />
            <ui:NavigationViewItem Content="Tweaks" Icon="{ui:SymbolIcon Wrench24}" />
          </ui:NavigationView.MenuItems>
          <ui:NavigationView.FooterMenuItems>
            <ui:NavigationViewItem Content="Activity Log" Icon="{ui:SymbolIcon History24}" />
            <ui:NavigationViewItem Content="Settings" Icon="{ui:SymbolIcon Settings24}" />
          </ui:NavigationView.FooterMenuItems>
        </ui:NavigationView>

        <Frame Grid.Column="1" x:Name="RootFrame" NavigationUIVisibility="Hidden" Background="Transparent" />
    </Grid>
  </Grid>
</ui:FluentWindow>
