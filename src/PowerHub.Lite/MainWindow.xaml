<Window x:Class="PowerHub.Lite.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="PowerHub Lite" Height="600" Width="900"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Background="{DynamicResource {x:Static SystemColors.WindowBrushKey}}"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Title with Logo -->
        <Grid Grid.Row="0" Margin="0,0,0,15">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="PowerHub Lite" FontSize="28" FontWeight="Bold" VerticalAlignment="Center" Foreground="#0078D7"/>
            <TextBlock Grid.Column="1" Text="Native Windows Power &amp; Display Control" VerticalAlignment="Center" Margin="15,0,0,0" Opacity="0.7"/>
        </Grid>

        <TabControl x:Name="MainTabs" Grid.Row="1">
            <!-- Dashboard Tab -->
            <TabItem Header="Dashboard">
                <Grid Margin="10">
                    <StackPanel>
                        <TextBlock Text="System Status" FontSize="20" FontWeight="Bold" Margin="0,0,0,10"/>
                        <Border BorderBrush="{DynamicResource {x:Static SystemColors.ActiveBorderBrushKey}}" BorderThickness="1" CornerRadius="4" Padding="15">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                
                                <TextBlock Text="Active Power Plan:" Margin="0,5"/>
                                <TextBlock x:Name="ActivePlanText" Grid.Column="1" FontWeight="Bold" HorizontalAlignment="Left" Text="Loading..." Margin="0,5"/>

                                <TextBlock Text="Power Mode:" Grid.Row="1" Margin="0,5"/>
                                <TextBlock x:Name="ActiveModeText" Grid.Row="1" Grid.Column="1" FontWeight="Bold" HorizontalAlignment="Left" Text="Loading..." Margin="0,5"/>

                                <TextBlock Text="Display Refresh Rate:" Grid.Row="2" Margin="0,5"/>
                                <TextBlock x:Name="RefreshRateText" Grid.Row="2" Grid.Column="1" FontWeight="Bold" HorizontalAlignment="Left" Text="Loading..." Margin="0,5"/>

                                <TextBlock Text="Battery Saver:" Grid.Row="3" Margin="0,5"/>
                                <TextBlock x:Name="BatterySaverText" Grid.Row="3" Grid.Column="1" FontWeight="Bold" HorizontalAlignment="Left" Text="Loading..." Margin="0,5"/>
                            </Grid>
                        </Border>
                        <Button Content="Refresh Info" Click="RefreshInfo_Click" Margin="0,15,0,0" Padding="15,5" HorizontalAlignment="Left"/>
                    </StackPanel>
                </Grid>
            </TabItem>

            <!-- Power Plans Tab -->
            <TabItem Header="Power Plans">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    
                    <TextBlock Text="Available Power Plans" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,10"/>
                    
                    <ListBox x:Name="PlansListBox" Grid.Row="1" Margin="0,0,0,10">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="5">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Text="{Binding DisplayName}" FontWeight="Bold"/>
                                        <TextBlock Text="{Binding Description}" FontSize="11" Opacity="0.7" TextWrapping="Wrap"/>
                                    </StackPanel>
                                    <Button Grid.Column="1" Content="Activate" Margin="10,0,0,0" Padding="10,2" CommandParameter="{Binding}" Click="ActivatePlan_Click" VerticalAlignment="Center"/>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <StackPanel Grid.Row="2" Orientation="Horizontal">
                        <Button Content="Unlock Standard Plans" Click="UnlockPlans_Click" Padding="15,5" Margin="0,0,10,0"/>
                        <Button Content="Import Power Scheme (.pow)" Click="ImportPlan_Click" Padding="15,5"/>
                    </StackPanel>
                </Grid>
            </TabItem>

            <!-- Power Modes Tab -->
            <TabItem Header="Power Modes">
                <Grid Margin="10">
                    <StackPanel>
                        <TextBlock Text="Power Mode" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,5"/>
                        <TextBlock Text="Optimize your device based on power use and performance" FontSize="12" Opacity="0.7" Margin="0,0,0,20"/>
                        
                        <!-- Plugged in Power Mode -->
                        <Border BorderBrush="{DynamicResource {x:Static SystemColors.ActiveBorderBrushKey}}" BorderThickness="1" CornerRadius="4" Padding="15" Margin="0,0,0,15">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="200"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                
                                <TextBlock Text="Plugged in" FontSize="14" FontWeight="Normal"/>
                                <ComboBox x:Name="PluggedInModeCombo" Grid.Column="1" Grid.Row="0" Height="35">
                                    <ComboBoxItem>Best Performance</ComboBoxItem>
                                    <ComboBoxItem>Balanced</ComboBoxItem>
                                    <ComboBoxItem>Best Battery Saver</ComboBoxItem>
                                </ComboBox>
                                
                                <TextBlock Grid.Row="1" x:Name="PluggedInModeDesc" Text="Maximize performance for demanding tasks" FontSize="12" Opacity="0.7" Margin="0,8,0,0"/>
                                <Button Grid.Column="1" Grid.Row="1" x:Name="ApplyPluggedInBtn" Content="Apply" Click="ApplyPluggedInMode_Click" Padding="10,5" HorizontalAlignment="Right" Background="#0078D7" Foreground="White" VerticalAlignment="Center" Margin="0,8,0,0"/>
                            </Grid>
                        </Border>

                        <!-- On battery Power Mode -->
                        <Border BorderBrush="{DynamicResource {x:Static SystemColors.ActiveBorderBrushKey}}" BorderThickness="1" CornerRadius="4" Padding="15">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="200"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                
                                <TextBlock Text="On battery" FontSize="14" FontWeight="Normal"/>
                                <ComboBox x:Name="OnBatteryModeCombo" Grid.Column="1" Grid.Row="0" Height="35">
                                    <ComboBoxItem>Best Performance</ComboBoxItem>
                                    <ComboBoxItem>Balanced</ComboBoxItem>
                                    <ComboBoxItem>Best Battery Saver</ComboBoxItem>
                                </ComboBox>
                                
                                <TextBlock Grid.Row="1" x:Name="OnBatteryModeDesc" Text="Maximize battery life while maintaining performance" FontSize="12" Opacity="0.7" Margin="0,8,0,0"/>
                                <Button Grid.Column="1" Grid.Row="1" x:Name="ApplyOnBatteryBtn" Content="Apply" Click="ApplyOnBatteryMode_Click" Padding="10,5" HorizontalAlignment="Right" Background="#0078D7" Foreground="White" VerticalAlignment="Center" Margin="0,8,0,0"/>
                            </Grid>
                        </Border>
                    </StackPanel>
                </Grid>
            </TabItem>

            <!-- Display Tab -->
            <TabItem Header="Display">
                <Grid Margin="10">
                    <StackPanel>
                        <TextBlock Text="Display Settings" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,10"/>
                        
                        <!-- Refresh Rate Section -->
                        <Border BorderBrush="{DynamicResource {x:Static SystemColors.ActiveBorderBrushKey}}" BorderThickness="1" CornerRadius="4" Padding="15" Margin="0,0,0,15">
                            <StackPanel>
                                <TextBlock Text="Refresh Rate" FontWeight="Bold" FontSize="14" Margin="0,0,0,10"/>
                                <TextBlock x:Name="CurrentRefreshText" FontSize="12" Opacity="0.7" Margin="0,0,0,10"/>
                                
                                <ComboBox x:Name="RefreshRateCombo" Height="35" Margin="0,0,0,10"/>
                                <Button Content="Apply Refresh Rate" Click="ApplyRefreshRate_Click" Padding="15,8" HorizontalAlignment="Left" Background="#0078D7" Foreground="White"/>
                                <TextBlock x:Name="RefreshStatusText" Text="Ready" Margin="0,10,0,0" FontStyle="Italic" Foreground="#0078D7"/>
                            </StackPanel>
                        </Border>

                        <Border BorderBrush="{DynamicResource {x:Static SystemColors.ActiveBorderBrushKey}}" BorderThickness="1" CornerRadius="4" Padding="15">
                            <StackPanel>
                                <TextBlock Text="Display Settings Info" FontWeight="Bold" Margin="0,0,0,10"/>
                                <TextBlock Text="• Changes apply immediately" Margin="10,2" FontSize="12"/>
                                <TextBlock Text="• Requires administrator privileges" Margin="10,2" FontSize="12"/>
                                <TextBlock Text="• Select a refresh rate and click Apply" Margin="10,2" FontSize="12"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Grid>
            </TabItem>

            <!-- Optimization Tab -->
            <TabItem Header="One-Click Boost">
                <Grid Margin="10">
                    <StackPanel>
                        <TextBlock Text="Optimization Suite" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,10"/>
                        <TextBlock Text="Apply a collection of system tweaks to improve responsiveness and reduce latency." TextWrapping="Wrap" Margin="0,0,0,20"/>
                        
                        <Border BorderBrush="{DynamicResource {x:Static SystemColors.ActiveBorderBrushKey}}" BorderThickness="1" CornerRadius="4" Padding="20">
                            <StackPanel>
                                <TextBlock Text="Included Optimizations:" FontWeight="Bold" Margin="0,0,0,5"/>
                                <TextBlock Text="• Flush DNS Resolver Cache" Margin="10,2"/>
                                <TextBlock Text="• Trim RAM Working Set" Margin="10,2"/>
                                <TextBlock Text="• Clear Temporary Files" Margin="10,2"/>
                                <TextBlock Text="• Enable System Performance Profiles" Margin="10,2"/>
                                <TextBlock Text="• Disable Background Telemetry" Margin="10,2"/>
                                
                                <Button Content="RUN ONE-CLICK BOOST" Click="RunBoost_Click" Margin="0,20,0,0" Padding="30,10" FontWeight="Bold" HorizontalAlignment="Center" Background="#0078D7" Foreground="White"/>
                            </StackPanel>
                        </Border>
                        
                        <TextBlock x:Name="BoostStatusText" Text="Ready" Margin="0,15,0,0" FontStyle="Italic" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Grid>
            </TabItem>
        </TabControl>
    </Grid>
</Window>
